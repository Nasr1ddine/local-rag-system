# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Ollama ────────────────────────────────────────────────────────────────────
# When running locally: http://localhost:11434
# When running via docker-compose: http://ollama:11434
OLLAMA_HOST=http://localhost:11434

# ── Model Configuration ───────────────────────────────────────────────────────
LLM_MODEL=llama3.1
EMBEDDING_MODEL=nomic-embed-text

# ── RAG Tuning ────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
